  <style>
    /* ===== Bracket styling (scoped to this page only) ===== */
    .bracket-wrap { overflow-x: auto; padding-bottom: 1rem; }
    .bracket {
      display: flex;
      align-items: stretch;
      gap: 28px;
      min-width: max-content;
    }
    .round {
      display: flex;
      flex-direction: column;
      justify-content: space-around;
      gap: 14px;
      min-width: 170px;
    }
    .round-title {
      text-align: center;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 8px;
      font-weight: 600;
    }
    .match {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .team {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      padding: 7px 10px;
      font-size: 0.85rem;
      color: var(--text);
    }
    .team + .team { border-top: 1px solid var(--border); }
    .team .name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .team .name.tbd { color: var(--muted); font-style: italic; }
    .team .score {
      min-width: 20px;
      text-align: center;
      color: var(--muted);
      font-variant-numeric: tabular-nums;
    }
    /* Mark a winner: add class="win" to the advancing .team */
    .team.win .name { color: var(--accent); font-weight: 600; }
    .team.win .score { color: var(--accent); font-weight: 600; }

    .round.final-col { justify-content: center; }
    .match.final {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px var(--accent) inset;
    }
    .champion {
      margin-top: 14px;
      text-align: center;
      font-size: 0.85rem;
      color: var(--muted);
    }
    .champion strong { color: var(--accent); }

    .third-place {
      margin-top: 26px;
      max-width: 220px;
    }
    .third-place .round-title { text-align: left; }

    /* On narrow screens the bracket scrolls horizontally (min-width keeps shape).
       Hint the user it's scrollable. */
    @media (max-width: 900px) {
      .scroll-hint { display: block; }
    }
    .scroll-hint { display: none; color: var(--muted); font-size: 0.8rem; margin: 0 0 10px; }

    /* ===== Auth bar ===== */
    #auth-bar {
      display: flex; flex-wrap: wrap; align-items: center; gap: 8px;
      margin: 14px 0 8px;
    }
    .auth-in {
      background: var(--card); border: 1px solid var(--border); color: var(--text);
      border-radius: 6px; padding: 6px 9px; font: inherit; font-size: 0.85rem; min-width: 130px;
    }
    .auth-btn { padding: 6px 14px; font-size: 0.85rem; cursor: pointer; }
    .auth-who { color: var(--muted); font-size: 0.9rem; }
    .auth-who strong { color: var(--accent); }
    .auth-msg { font-size: 0.8rem; color: var(--muted); }
    .auth-msg.err { color: #ff8c8c; }

    /* ===== Prediction fixtures ===== */
    .fixtures {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 16px;
      margin-bottom: 28px;
    }
    .fx-group {
      background: var(--card); border: 1px solid var(--border);
      border-radius: 8px; padding: 10px 12px;
    }
    .fx-group h4 {
      margin: 0 0 8px; font-size: 0.78rem; letter-spacing: 0.05em;
      text-transform: uppercase; color: var(--accent);
    }
    .fixture {
      display: grid;
      grid-template-columns: 40px 1fr auto 1fr 30px;
      align-items: center; gap: 6px;
      padding: 5px 0; font-size: 0.82rem;
      border-top: 1px solid var(--border);
    }
    .fixture:first-of-type { border-top: 0; }
    .fixture.locked { opacity: 0.72; }
    .fx-kick { color: var(--muted); font-size: 0.7rem; white-space: nowrap; }
    .fx-team { color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .fx-team.away { text-align: right; }
    .fx-pred { display: flex; align-items: center; gap: 3px; justify-self: center; }
    .fx-colon { color: var(--muted); }
    .pred-in {
      width: 34px; text-align: center; font: inherit; font-size: 0.82rem;
      background: var(--bg); border: 1px solid var(--border); color: var(--text);
      border-radius: 5px; padding: 3px 2px;
      -moz-appearance: textfield;
    }
    .pred-in::-webkit-outer-spin-button, .pred-in::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .pred-in:disabled { opacity: 0.5; cursor: not-allowed; }
    .fx-result { color: var(--accent); font-weight: 600; text-align: right; font-size: 0.78rem; }
    .pred-status { grid-column: 1 / -1; font-size: 0.7rem; color: var(--muted); min-height: 0; }
    .pred-status.ok { color: #7ee0a0; }
    .pred-status.err { color: #ff8c8c; }
    .pred-status:empty { display: none; }

    /* ===== Leaderboard ===== */
    .lb-table { width: 100%; border-collapse: collapse; max-width: 480px; font-size: 0.88rem; }
    .lb-table th, .lb-table td { padding: 7px 10px; text-align: center; }
    .lb-table th.team-cell, .lb-table td.team-cell { text-align: left; color: var(--text); }
    .lb-table thead th {
      font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.04em;
      color: var(--muted); border-bottom: 1px solid var(--border);
    }
    .lb-table tbody tr { border-top: 1px solid var(--border); }
    .lb-table tbody td { color: var(--muted); }
    .lb-table tbody tr.lb-me td { color: var(--accent); font-weight: 600; }
  </style>
